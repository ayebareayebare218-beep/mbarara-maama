<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="MaternaCheck"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#6200EA"
                android:layout_marginTop="10dp"/>

            <!-- Purple Hero Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardBackgroundColor="#6200EA"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Hello, Mama 👋"
                        android:textColor="#FFFFFF"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Monitor your maternal health with on-device AI - completely private, no internet required."
                        android:textColor="#D1C4E9"
                        android:layout_marginTop="8dp"
                        android:lineSpacingExtra="4dp"/>

                    <Button
                        android:id="@+id/btnGoToAssess"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="20dp"
                        android:text="START ASSESSMENT"
                        android:backgroundTint="#FFFFFF"
                        android:textColor="#6200EA"
                        android:textStyle="bold"
                        android:paddingLeft="20dp"
                        android:paddingRight="20dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:weightSum="2">

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:padding="16dp" android:gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="AI" android:textSize="20sp" android:textColor="#F44336" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Active Model" android:textSize="12sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    app:cardCornerRadius="12dp">
                    <LinearLayout android:padding="16dp" android:gravity="center" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Offline" android:textSize="20sp" android:textColor="#4CAF50" android:textStyle="bold"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Security Mode" android:textSize="12sp"/>
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Access"
                android:layout_marginTop="24dp"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#333333"/>

            <!-- Navigation Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp"
                android:weightSum="2">

                <Button
                    android:id="@+id/btnViewHistory"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:text="History"
                    android:layout_marginEnd="8dp"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="#6200EA"
                    app:strokeColor="#E0E0E0"
                    app:strokeWidth="1dp"/>

                <!-- ADDED ID TO THIS BUTTON -->
                <Button
                    android:id="@+id/btnLearn"
                    android:layout_width="0dp"
                    android:layout_height="100dp"
                    android:layout_weight="1"
                    android:text="Learn"
                    android:backgroundTint="#FFFFFF"
                    android:textColor="#6200EA"
                    app:strokeColor="#E0E0E0"
                    app:strokeWidth="1dp"/>
            </LinearLayout>

            <!-- Yellow Warning Disclaimer -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="30dp"
                android:layout_marginBottom="20dp"
                app:cardBackgroundColor="#FFF9C4"
                app:cardCornerRadius="12dp"
                app:cardElevation="0dp">
                <TextView
                    android:padding="16dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textSize="13sp"
                    android:textColor="#F57F17"
                    android:text="⚠️ Disclaimer: This app is a screening tool only and does not replace professional medical advice. Always consult a qualified healthcare provider."/>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</RelativeLayout>