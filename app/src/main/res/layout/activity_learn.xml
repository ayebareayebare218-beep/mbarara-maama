<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F8F9FA"
    android:padding="16dp">

    <!-- ScrollView takes up remaining space with layout_weight="1" -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Mama's Learning Center"
                android:textColor="#6200EA"
                android:textSize="24sp"
                android:textStyle="bold"
                android:gravity="center"
                android:layout_marginBottom="20dp"/>

            <!-- Danger Signs Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#FFEBEE"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout android:padding="16dp" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="🚨 Danger Signs" android:textSize="18sp" android:textStyle="bold" android:textColor="#D32F2F" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Go to the hospital IMMEDIATELY if you experience:\n• Vaginal bleeding\n• Severe headaches or blurred vision\n• Baby stops moving\n• Water breaks before labor\n• Swollen face/hands" android:textSize="14sp" android:textColor="#333333" android:layout_marginTop="8dp" android:lineSpacingExtra="4dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Nutrition Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#E8F5E9"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout android:padding="16dp" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="🥗 Healthy Nutrition" android:textSize="18sp" android:textStyle="bold" android:textColor="#2E7D32" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="To keep your blood levels (Hemoglobin) strong:\n• Eat dark green vegetables (Dodo, Spinach)\n• Beans, peas, and iron-rich foods\n• Drink plenty of clean, safe water\n• Take your folic acid/iron tablets daily" android:textSize="14sp" android:textColor="#333333" android:layout_marginTop="8dp" android:lineSpacingExtra="4dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Mama Kit / Prep Card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                app:cardBackgroundColor="#E3F2FD"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp">
                <LinearLayout android:padding="16dp" android:orientation="vertical" android:layout_width="match_parent" android:layout_height="wrap_content">
                    <TextView android:text="🎒 Preparing for Birth" android:textSize="18sp" android:textStyle="bold" android:textColor="#1565C0" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                    <TextView android:text="Have your Mama Kit ready by 7 months:\n• Cotton wool and sterile gloves\n• Polythene sheet and razor blades\n• Clean baby clothes and blankets\n• Save money for transport to the clinic" android:textSize="14sp" android:textColor="#333333" android:layout_marginTop="8dp" android:lineSpacingExtra="4dp" android:layout_width="wrap_content" android:layout_height="wrap_content"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>

    <!-- The Back to Dashboard Button fixed at the bottom -->
    <Button
        android:id="@+id/btnCloseLearn"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="10dp"
        android:text="BACK TO DASHBOARD"
        android:backgroundTint="#6200EA"
        android:textColor="#FFFFFF"
        android:textStyle="bold" />

</LinearLayout>