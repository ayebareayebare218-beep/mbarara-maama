<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    tools:context=".AssessmentActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Maternal Risk Assessment"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#6200EA"
            android:gravity="center"
            android:layout_marginBottom="30dp"/>

        <EditText
            android:id="@+id/editAge"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Age (years)"
            android:inputType="number"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="12dp"
            android:padding="10dp" />

        <EditText
            android:id="@+id/editSystolicBP"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Systolic BP (e.g. 120)"
            android:inputType="number"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="12dp"
            android:padding="10dp" />

        <EditText
            android:id="@+id/editDiastolicBP"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Diastolic BP (e.g. 80)"
            android:inputType="number"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="12dp"
            android:padding="10dp" />

        <!-- NEW FIELD: Hemoglobin -->
        <EditText
            android:id="@+id/editHemoglobin"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Hemoglobin Level (g/dL)"
            android:inputType="numberDecimal"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="12dp"
            android:padding="10dp" />

        <!-- NEW FIELD: Antenatal Visits -->
        <EditText
            android:id="@+id/editVisits"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Number of Antenatal Visits"
            android:inputType="number"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="12dp"
            android:padding="10dp" />

        <!-- NEW FIELD: Previous Complications -->
        <EditText
            android:id="@+id/editComplications"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:hint="Prev. Complications (1 for Yes, 0 for No)"
            android:inputType="number"
            android:background="@android:drawable/editbox_background"
            android:layout_marginBottom="25dp"
            android:padding="10dp" />

        <Button
            android:id="@+id/btnAssess"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="ANALYZE RISK"
            android:backgroundTint="#6200EA"
            android:textColor="#FFFFFF"
            android:textStyle="bold"
            android:layout_marginBottom="30dp"/>

        <LinearLayout
            android:id="@+id/resultLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp"
            android:visibility="gone"
            android:background="#F0F0F0"
            android:layout_marginBottom="40dp">

            <TextView
                android:id="@+id/textResultTitle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#000000"
                android:gravity="center"/>

            <TextView
                android:id="@+id/textResultAction"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="16sp"
                android:textColor="#000000"
                android:gravity="center"
                android:layout_marginTop="10dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>